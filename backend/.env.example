# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projectalpha

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=Project Alpha

# CORS (逗号分隔)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Environment: development / production
ENVIRONMENT=development

# JWT（生产环境请使用 openssl rand -hex 32 生成两个不同的密钥）
JWT_SECRET_KEY=change-me-access-secret
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-different
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# DB 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# 是否允许 POST /api/v1/auth/register 自助注册
AUTH_ALLOW_REGISTER=true

# 安全响应头（JSON API 建议开启）
ENABLE_SECURITY_HEADERS=true

# 生产环境建议填写允许的主机名，逗号分隔；留空则不校验 Host
# TRUSTED_HOSTS=api.example.com,localhost

# 认证接口限流（slowapi 格式，如 20/minute）
RATE_LIMIT_AUTH_LOGIN=20/minute
RATE_LIMIT_AUTH_REGISTER=8/minute
RATE_LIMIT_AUTH_REFRESH=60/minute
RATE_LIMIT_AUTH_CHANGE_PASSWORD=15/minute
